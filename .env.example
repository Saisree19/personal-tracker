# Shared
JWT_SECRET=dev-secret-key-32-chars-long-123456
DB_USERNAME=tracker
DB_PASSWORD=tracker

# Database URLs (override if needed)
AUTH_R2DBC_URL=r2dbc:postgresql://db:5432/personal_tracker_auth
TASK_R2DBC_URL=r2dbc:postgresql://db:5432/personal_tracker_task
REPORTING_R2DBC_URL=r2dbc:postgresql://db:5432/personal_tracker_task

# SMTP for password reset (auth-service)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM=your-email@gmail.com
RESET_FRONTEND_URL=http://localhost:80/reset
MAIL_SINK_ENABLED=true

# Frontend build-time API endpoints
VITE_AUTH_URL=http://localhost:8081
VITE_TASK_URL=http://localhost:8082
VITE_REPORT_URL=http://localhost:8083
