############################################
# Shared Configuration
############################################

# JWT secret (MUST be long & random in real usage)
JWT_SECRET=CHANGE_ME_SUPER_LONG_RANDOM_SECRET

# Database credentials
DB_USERNAME=CHANGE_ME
DB_PASSWORD=CHANGE_ME


############################################
# Database URLs
############################################

# Local Docker setup
AUTH_R2DBC_URL=r2dbc:postgresql://db:5432/personal_tracker_auth
TASK_R2DBC_URL=r2dbc:postgresql://db:5432/personal_tracker_task
REPORTING_R2DBC_URL=r2dbc:postgresql://db:5432/personal_tracker_task

# Example for local non-docker usage:
# AUTH_R2DBC_URL=r2dbc:postgresql://localhost:5432/personal_tracker_auth


############################################
# SMTP Configuration (Password Reset)
############################################

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME_APP_PASSWORD
SMTP_FROM=CHANGE_ME

# Frontend reset URL
RESET_FRONTEND_URL=http://localhost:5173/reset

# Mail sink (true = logs emails instead of sending)
MAIL_SINK_ENABLED=true


############################################
# Frontend API Endpoints (Vite)
############################################

VITE_AUTH_URL=http://localhost:8081
VITE_TASK_URL=http://localhost:8082
VITE_REPORT_URL=http://localhost:8083